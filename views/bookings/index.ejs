<% layout("/layouts/boilerplate.ejs") %>

<div class="row mt-4">
  <div class="col-8 offset-2">
    <h3>My Bookings</h3>
    <hr>
    <% if(bookings.length === 0) { %>
      <p class="text-muted">You have no bookings yet. <a href="/listings">Browse listings</a></p>
    <% } else { %>
      <% for(let booking of bookings) { %>
        <div class="card mb-3 shadow-sm">
          <div class="row g-0">
            <div class="col-md-3">
              <img src="<%= booking.listing.image.url %>" class="img-fluid rounded-start" style="height:150px; object-fit:cover;" alt="listing">
            </div>
            <div class="col-md-9">
              <div class="card-body">
                <h5 class="card-title"><%= booking.listing.title %></h5>
                <p class="card-text mb-1">
                  <b>Check-in:</b> <%= new Date(booking.checkIn).toDateString() %> &nbsp;|&nbsp;
                  <b>Check-out:</b> <%= new Date(booking.checkOut).toDateString() %>
                </p>
                <p class="card-text mb-1">
                  <b>Nights:</b> <%= booking.totalNights %> &nbsp;|&nbsp;
                  <b>Total:</b> &#8377;<%= booking.totalPrice.toLocaleString("en-IN") %>
                </p>
                <span class="badge bg-success"><%= booking.status %></span>
                <a href="/bookings/<%= booking._id %>" class="btn btn-sm btn-dark ms-2">View</a>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    <% } %>
  </div>
</div>