<% layout("/layouts/boilerplate.ejs") %>
<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>
<div class="row">
  <div class="col-8 offset-3 mt-3">
    <h3><%= listing.title %></h3>
  </div>

  <div class="col-6 offset-3 show-card listing-card">
    <img
      src="<%= listing.image.url %>"
      class="card-img-top show-img"
      alt="Listing_img"
    />

    <div class="card-body">
      <p class="card-text">
        Owned By: <%= listing.owner.username %><br />
        <%= listing.description %><br />
        &#8377;<%= listing.price.toLocaleString("en-IN") %><br />
        <%= listing.country %><br />
        <%= listing.location %>
      </p>
    </div>
  </div>
</div>

<!-- EDIT & DELETE BUTTONS (ONLY OWNER) -->

<% if(currUser && listing.owner._id.equals(currUser._id)) { %>

<div class="btns mt-2">
  <a
    href="/listings/<%= listing._id %>/edit"
    class="btn btn-dark col-1 offset-3 edit-btn"
  >
    Edit
  </a>

  <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
    <button class="btn btn-dark offset-5">
      Delete
    </button>
  </form>
</div>

<% } %>


<div class="col-8 offset-2 mb-3">

<!-- BOOKING SECTION -->
<% if(currUser && !listing.owner._id.equals(currUser._id)) { %>
<div class="d-flex justify-content-center mt-3 mb-3">
  <div style="width: 55%;">
    <div class="card shadow-sm p-4">
      <h4>&#8377;<%= listing.price.toLocaleString("en-IN") %> <span style="font-size:1rem; font-weight:normal;">/night</span></h4>
      <hr>
      <div class="row">
        <div class="col-6 mb-3">
          <label class="form-label"><b>Check-in</b></label>
          <input type="date" id="checkIn" class="form-control" min="<%= new Date().toISOString().split('T')[0] %>" />
        </div>
        <div class="col-6 mb-3">
          <label class="form-label"><b>Check-out</b></label>
          <input type="date" id="checkOut" class="form-control" min="<%= new Date().toISOString().split('T')[0] %>" />
        </div>
      </div>
      <div id="priceBreakdown" class="mb-3" style="display:none;">
        <hr>
        <div class="d-flex justify-content-between">
          <span id="nightsText"></span>
          <span id="nightsPrice"></span>
        </div>
        <div class="d-flex justify-content-between mt-2">
          <b>Total</b>
          <b id="totalPrice"></b>
        </div>
      </div>
      <button id="bookNowBtn" class="btn btn-dark w-100" style="display:none;">Book Now</button>
      <p id="selectDatesMsg" class="text-muted text-center mt-2">Select dates to see price</p>
    </div>
  </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  const checkInInput = document.getElementById("checkIn");
  const checkOutInput = document.getElementById("checkOut");
  const priceBreakdown = document.getElementById("priceBreakdown");
  const bookNowBtn = document.getElementById("bookNowBtn");
  const selectDatesMsg = document.getElementById("selectDatesMsg");
  const listingPrice = <%= listing.price %>;
  const listingId = "<%= listing._id %>";

  function updatePriceBreakdown() {
    const checkIn = new Date(checkInInput.value);
    const checkOut = new Date(checkOutInput.value);

    if (checkInInput.value && checkOutInput.value && checkOut > checkIn) {
      const nights = Math.ceil((checkOut - checkIn) / (1000 * 60 * 60 * 24));
      const total = nights * listingPrice;

      document.getElementById("nightsText").textContent = `₹${listingPrice.toLocaleString("en-IN")} x ${nights} nights`;
      document.getElementById("nightsPrice").textContent = `₹${total.toLocaleString("en-IN")}`;
      document.getElementById("totalPrice").textContent = `₹${total.toLocaleString("en-IN")}`;

      priceBreakdown.style.display = "block";
      bookNowBtn.style.display = "block";
      selectDatesMsg.style.display = "none";
    } else {
      priceBreakdown.style.display = "none";
      bookNowBtn.style.display = "none";
      selectDatesMsg.style.display = "block";
    }
  }

  checkInInput.addEventListener("change", () => {
    checkOutInput.min = checkInInput.value;
    updatePriceBreakdown();
  });

  checkOutInput.addEventListener("change", updatePriceBreakdown);

  bookNowBtn.addEventListener("click", async () => {
    const checkIn = checkInInput.value;
    const checkOut = checkOutInput.value;

    const res = await fetch("/bookings/create-order", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ listingId, checkIn, checkOut }),
    });

    const data = await res.json();

    if (data.error) {
      alert(data.error);
      return;
    }

    const options = {
      key: data.keyId,
      amount: data.amount,
      currency: data.currency,
      name: "WanderLust",
      description: data.listing.title,
      order_id: data.orderId,
      handler: async function (response) {
        const verifyRes = await fetch("/bookings/verify-payment", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            razorpay_order_id: response.razorpay_order_id,
            razorpay_payment_id: response.razorpay_payment_id,
            razorpay_signature: response.razorpay_signature,
            listingId,
            checkIn,
            checkOut,
            totalNights: data.totalNights,
            totalPrice: data.totalPrice,
          }),
        });

        if (verifyRes.redirected) {
          window.location.href = verifyRes.url;
        }
      },
      prefill: {
        name: "<%= currUser.username %>",
        email: "<%= currUser.email %>",
      },
      theme: {
        color: "#fe424d",
      },
    };

    const rzp = new Razorpay(options);
    rzp.open();
  });
</script>
<% } %>

<% if(currUser && listing.owner._id.equals(currUser._id)) { %>
<div class="d-flex justify-content-center mt-3 mb-3">
  <div style="width: 55%;">
    <div class="card shadow-sm p-4 text-center">
      <p class="text-muted">You own this listing.</p>
    </div>
  </div>
</div>
<% } %>

<% if(!currUser) { %>
<div class="d-flex justify-content-center mt-3 mb-3">
  <div style="width: 55%;">
    <div class="card shadow-sm p-4 text-center">
      <p class="text-muted">Please <a href="/login">login</a> to book this listing.</p>
    </div>
  </div>
</div>
<% } %>

<!-- REVIEW FORM (ONLY LOGGED IN USERS) -->

<% if(currUser) { %>
<hr>
<h4>Leave A Review</h4>

<form
  method="POST"
  action="/listings/<%= listing._id %>/reviews"
  novalidate
  class="needs-validation"
>
<div class="mb-3 mt-3">
<label for="rating" class="form-label">Rating</label>

<fieldset class="starability-slot">

<input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />

<input type="radio" id="first-rate1" name="review[rating]" value="1" />
<label for="first-rate1" title="Terrible">1 star</label>

<input type="radio" id="first-rate2" name="review[rating]" value="2" />
<label for="first-rate2" title="Not good">2 stars</label>

<input type="radio" id="first-rate3" name="review[rating]" value="3" />
<label for="first-rate3" title="Average">3 stars</label>

<input type="radio" id="first-rate4" name="review[rating]" value="4" />
<label for="first-rate4" title="Very good">4 stars</label>

<input type="radio" id="first-rate5" name="review[rating]" value="5" />
<label for="first-rate5" title="Amazing">5 stars</label>

</fieldset>
</div>



  <div class="mb-3 mt-3">

    <label for="comment" class="form-label">Comments</label>

    <textarea
      name="review[comment]"
      id="comment"
      cols="30"
      rows="5"
      class="form-control"
      required
    ></textarea>

    <div class="invalid-feedback">
      Please Enter Comment
    </div>

  </div>

  <button class="btn btn-outline-dark">
    Submit
  </button>

</form>

<% } else { %>

<p class="text-muted">
  Please <a href="/login">login</a> to leave a review.
</p>

<% } %>


<hr>


<!-- ALL REVIEWS -->
<% if(listing.reviews.length > 0){ %>
<div class="row">
<p><b>All Reviews</b></p>
  <% for(let review of listing.reviews) { %>

  <div class="card col-5 ms-3 mb-3">

    <div class="card-body">

      <h5 class="card-title mt-2">
        @<%= review.author.username %>
      </h5>
      <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
      <p class="card-text">
        <%= review.comment %>
      </p>

    </div>


    <% if(currUser) { %>

    <form
      method="POST"
      action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
    >

      <button class="btn btn-sm btn-dark mb-3 mt-2">
        Delete
      </button>

    </form>

    <% } %>

  </div>

  <% } %>

  
</div>
<% } %>
</div>

<div class="col-8 offset-2 mb-3">
    <h3>Where You'll Be</h3>
     <div id="map"></div>
  </div>
  </div>

  <script src="/js/map.js"></script>
